NEXT_PUBLIC_DOC_URL=https://docs.canvas.best

# === 充值系统配置 ===
# 站点 URL（用于支付回调地址）
NEXT_PUBLIC_APP_URL=https://infcanvas.gamezipper.com
# 站点名称（显示在支付标题）
NEXT_PUBLIC_APP_NAME=无限画布
# 支付配置加密密钥（AES-256-GCM，32字节 hex 格式）
PAYMENT_CONFIG_ENCRYPTION_KEY=
# 定时任务密钥
CRON_SECRET=

# 订单限额
ORDER_TIMEOUT_MINUTES=10
MIN_RECHARGE_AMOUNT=1
MAX_RECHARGE_AMOUNT=5000
MAX_DAILY_RECHARGE_AMOUNT=10000
MAX_PENDING_ORDERS=3

# 支付商支持的支付方式（逗号分隔：easypay,stripe）
# 支付商配置通过管理后台在线配置（加密存储），此处仅设置限额覆盖
# FEE_RATE_ALIPAY=0
# FEE_RATE_WXPAY=0
# FEE_RATE_STRIPE=0
# MAX_DAILY_AMOUNT_ALIPAY=10000
# MAX_DAILY_AMOUNT_WXPAY=10000
# MAX_DAILY_AMOUNT_STRIPE=0
